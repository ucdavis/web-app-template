@model server.core.Notifications.DefaultNotificationTemplateModel

@{
    Layout = "/Views/Shared/_NotificationLayout_mjml.cshtml";
}

<mj-section padding="36px 36px 12px 36px">
  <mj-column>
    <mj-text font-size="26px"
             font-weight="700"
             line-height="1.3"
             padding-bottom="12px">
      @Model.Header
    </mj-text>
    @foreach (var paragraph in Model.Paragraphs)
    {
      <mj-text padding="0px 0px 14px 0px">
        @paragraph
      </mj-text>
    }
  </mj-column>
</mj-section>

@if (!string.IsNullOrWhiteSpace(Model.ButtonText) && !string.IsNullOrWhiteSpace(Model.ButtonUrl))
{
  @await Html.PartialAsync("/Views/Shared/_NotificationButton_mjml.cshtml", new server.core.Notifications.NotificationButtonModel(Model.ButtonText, Model.ButtonUrl))
}
