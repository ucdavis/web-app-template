@model Server.Core.Notification.NotificationButtonModel

<mj-section background-color="#ffffff" padding="0px 0px 28px 0px">
  <mj-column>
    <mj-divider border-color="#dfe7f1" padding="0px 28px 20px 28px" />
    <mj-button background-color="#0b5fff"
               color="#ffffff"
               font-size="16px"
               font-weight="600"
               border-radius="999px"
               href="@Model.Url"
               padding="0px 24px"
               inner-padding="14px 30px">
      @Model.Text
    </mj-button>
  </mj-column>
</mj-section>
